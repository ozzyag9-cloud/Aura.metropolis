rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerified() { return isSignedIn(); }

    // --- Entity Validation Helpers ---
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid
        && data.displayName is string
        && (data.photoURL == null || data.photoURL is string)
        && data.totalInvested is number 
        && data.auraBalance is number
        && data.hasGoldVisaEligibility is bool
        && data.hasGoldPass is bool;
    }

    // --- Collection Rules ---

    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false; 
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    // Ownership NFTs (Fractional Stakes)
    match /ownership_nfts/{nftId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid && isValidId(nftId);
      allow create: if isVerified() && isValidId(nftId);
      allow update: if false; // Immutable
      allow delete: if false;
    }

    // Dynamic NFTs Collection
    match /nfts/{nftId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid && isValidId(nftId);
      allow create: if isVerified() && isValidId(nftId);
      allow update: if isOwner(existing().ownerId) && isValidId(nftId);
    }

    // Investments Transaction Log
    match /investments/{investmentId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(investmentId);
    }

    // Community Messages
    match /messages/{messageId} {
      allow list, get: if isSignedIn();
      allow create: if isVerified();
    }

    // Static/Public Collections
    match /estates/{estateId} { allow read: if true; }
    match /groceries/{groceryId} { allow read: if true; }
    match /art/{artId} { allow read: if true; }
    match /plots/{plotId} { allow read: if true; }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
